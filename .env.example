# --- LLM ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- LangSmith tracing (optional) ---
# Set to true and provide an API key to send traces to LangSmith.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=nlp2sql
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Database under query (read-only) ---
# Path to the Sakila SQLite file produced by `python data/setup_db.py`.
DB_PATH=data/sakila.db

# --- Agent behaviour ---
# Shared retry budget for the schema-guard (Node 6) and execute (Node 7) loops.
MAX_RETRIES=2

# --- Cache (table schemas + descriptions) ---
# memory | redis   (redis is not implemented yet; memory is the default)
CACHE_BACKEND=memory
# Used only when CACHE_BACKEND=redis (reserved for later).
REDIS_URL=redis://localhost:6379/0

# --- Conversation persistence ---
# LangGraph checkpointer (resume interrupted threads).
CHECKPOINT_DB_PATH=data/checkpoints.db
# Conversation ingestion store (audit/analytics; one row per turn).
CONVERSATION_DB_PATH=data/conversations.db
